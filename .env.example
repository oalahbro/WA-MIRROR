# Salin file ini menjadi .env lalu sesuaikan

# Port HTTP server (UI + API)
PORT=8088

# Alamat bind. Lokal: biarkan kosong / 0.0.0.0.
# Di VPS dengan akses via SSH tunnel: set 127.0.0.1 agar port hanya di loopback
# (tidak terjangkau dari internet).
# HOST=127.0.0.1

# Token rahasia untuk login ke UI. WAJIB diganti dengan string panjang & acak.
# Contoh generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
AUTH_TOKEN=ganti-dengan-token-rahasia-panjang

# Lokasi file database SQLite
DB_PATH=./data/wa.db

# Lokasi folder kredensial Baileys (jangan dihapus kalau sudah login)
AUTH_DIR=./auth

# Nomor TUJUAN semua notifikasi (di-tag, dibalas, & pengingat belum dibalas).
# KOSONGKAN = kirim ke diri sendiri / chat "Message Yourself" (nomor yang login).
# Isi nomor lain bila ingin notif masuk ke HP terpisah, format kode negara tanpa +/spasi.
# Contoh: OWNER_JID=6281234567890
OWNER_JID=

# Notifikasi saat di-tag / dibalas DI GRUP (default: aktif). Tidak langsung diforward —
# hanya bila tak kamu tanggapi dalam OWNER_PENDING_MINUTES menit (sama seperti chat pribadi),
# supaya tidak nge-spam saat grup ramai. Set 0 untuk mematikan jalur grup.
OWNER_NOTIFY=1
# Ikut forward pesan asli (termasuk media), bukan cuma teks detail. Set 0 = teks saja.
OWNER_NOTIFY_FORWARD=1

# Pengingat CHAT PRIBADI: bila pesan masuk belum kamu balas dalam N menit,
# teruskan ke nomor sendiri (default: aktif). Set OWNER_PENDING_NOTIFY=0 untuk mati.
# OWNER_PENDING_MINUTES dipakai bersama oleh jalur grup di atas.
OWNER_PENDING_NOTIFY=1
OWNER_PENDING_MINUTES=5

# Retensi media chat: file cache media (foto/video/dokumen/stiker) untuk pesan yang
# umurnya lebih dari N hari otomatis dihapus dari disk (hemat ruang; media WA juga sudah
# kedaluwarsa di server). Stiker FAVORIT & avatar tidak terpengaruh. Default 30. Set 0 = mati.
MEDIA_RETENTION_DAYS=30
